    # 2. Test Luxury Car
    my_luxury = Luxury("Mercedes", "S-Class", 100000)
    my_luxury.Show_CarInfo()
    my_luxury.set_option("GPS", "Y")
    my_luxury.set_option("Self-Driving", "Y")
    
    final_luxury_price = my_luxury.price_with_options()
    print(f"Final Luxury Price: ${final_luxury_price:,.2f}")

if __name__ == "__main__":
    main()
    
