#Employee
class Employee:
    Raise_Amt = 1.04
    
    def __init__(self,FstNme,LstNme,EmpPay):
        self.FstNme = FstNme
        self.LstNme = LstNme
        self.EmpPay = EmpPay
        self.Email = FstNme + '.' + LstNme + '@email.com'
    def FullName(self):
        return '{} {}'.format(self.FstNme, self.LstNme)
    
    def Apply_Raise(self):
        self.RasdPay = float(self.EmpPay) * float(self.Raise_Amt)
        return self.RasdPay
#Manager
class Manager(Employee):
    Raise_Amt = 1.40
    
    def LngTrmBns(self):
        self.RasdPay = float(self.EmpPay) * float(self.Raise_Amt)
        return self.RasdPay
#Executive
class Executive(Employee):
    Raise_Amt = 1.50
  
    def ExecPay(self):
        self.RasdPay = (2 * float(self.EmpPay)) * float(self.Raise_Amt)
        return self.RasdPay
